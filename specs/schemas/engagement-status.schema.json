{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuas.mil/schemas/engagement-status.schema.json",
  "title": "EngagementStatus",
  "description": "Lifecycle feedback for an engagement (Imperative 5). Published to cuas.engagement.status.{engagementId} on the T0 QoS tier so feedback is never delayed behind COP traffic.",
  "type": "object",
  "required": ["engagementId", "effectorId", "state", "sequence", "terminal", "timeReported"],
  "additionalProperties": false,
  "properties": {
    "engagementId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "effectorId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9_:@/-]{0,127}$" },
    "trackId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "state": {
      "type": "string",
      "enum": ["PROPOSED", "AUTHORIZED", "ACCEPTED", "ACTIVE", "ASSESSING", "COMPLETE", "ABORTED", "FAILED", "DENIED"],
      "description": "PROPOSED->AUTHORIZED->ACCEPTED->ACTIVE->ASSESSING->COMPLETE on the nominal path. COMPLETE means the engagement process ended; effectAssessment, not state, determines whether an effect was confirmed."
    },
    "sequence": {
      "type": "integer",
      "minimum": 1,
      "description": "Strictly increasing per-engagement sequence used to reject late, duplicate, or regressive lifecycle updates."
    },
    "terminal": {
      "type": "boolean",
      "description": "True only for COMPLETE, ABORTED, FAILED, or DENIED. No later state is valid after a terminal update."
    },
    "reasonCode": {
      "type": "string",
      "description": "Why a DENIED/ABORTED/FAILED state occurred.",
      "enum": [
        "OK",
        "TRACK_QUALITY_INSUFFICIENT",
        "EFFECTOR_UNAVAILABLE",
        "OUT_OF_ENVELOPE",
        "NOT_AUTHORIZED",
        "ROE_PROHIBITED",
        "WEAPONS_HOLD",
        "COLLATERAL_HOLD",
        "INTERLOCK_BLOCKED",
        "TRACK_STALE",
        "FRIENDLY_PROXIMITY",
        "OPERATOR_ABORT",
        "EFFECTOR_FAULT",
        "DUPLICATE_ORDER",
        "TRACK_NOT_FOUND",
        "MAGAZINE_EMPTY",
        "UNSUPPORTED_EFFECT",
        "EFFECT_NOT_APPLICABLE",
        "TOKEN_EXPIRED",
        "TOKEN_NOT_YET_VALID",
        "TOKEN_LIFETIME_EXCEEDED",
        "TOKEN_SCOPE_MISMATCH",
        "INVALID_AUTHORITY_SIGNATURE",
        "INVALID_AUTHORITY_CLAIMS",
        "MALFORMED_AUTHORITY_TOKEN",
        "UNSUPPORTED_TOKEN_VERSION",
        "WRONG_AUTHORITY_ISSUER",
        "ENGAGEMENT_NOT_ACTIVE",
        "ORDER_CONSTRAINT_UNSATISFIABLE",
        "INVALID_ORDER",
        "EFFECTOR_ACK_TIMEOUT"
      ]
    },
    "detail": { "type": "string", "description": "Human-readable amplification for the COP/audit." },
    "inventoryRemaining": { "type": "number", "minimum": 0, "description": "Effector capacity remaining after this transition, in the unit declared by EffectorStatus." },
    "effectAssessment": {
      "type": "object",
      "required": ["outcome", "confidence", "method", "timeAssessed"],
      "additionalProperties": false,
      "properties": {
        "outcome": { "type": "string", "enum": ["PENDING", "CONFIRMED_EFFECT", "NO_CONFIRMED_EFFECT", "INDETERMINATE"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "method": { "type": "string", "minLength": 1, "maxLength": 128 },
        "timeAssessed": { "type": "string", "format": "date-time" }
      }
    },
    "timeReported": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "state": { "enum": ["COMPLETE", "ABORTED", "FAILED", "DENIED"] } }, "required": ["state"] },
      "then": { "properties": { "terminal": { "const": true } } },
      "else": { "properties": { "terminal": { "const": false } } }
    },
    {
      "if": { "properties": { "state": { "const": "ASSESSING" } }, "required": ["state"] },
      "then": { "required": ["effectAssessment"] }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuas.mil/schemas/sensor-task.schema.json",
  "title": "SensorTask",
  "description": "A remote tasking command to a sensor (Imperative 4). Published to cuas.sensor.task.{sensorId}; subject to the tasking arbiter and the authority engine.",
  "type": "object",
  "required": ["taskId", "sensorId", "taskType", "priority", "requestedBy"],
  "additionalProperties": false,
  "properties": {
    "taskId": { "type": "string" },
    "sensorId": { "type": "string", "description": "Target sensor." },
    "taskType": {
      "type": "string",
      "enum": ["SEARCH", "CUE", "SLEW", "DWELL", "HANDOFF"],
      "description": "CUE/SLEW/DWELL raise track quality on a specific track; HANDOFF transfers custody."
    },
    "trackId": { "type": "string", "description": "Track to cue/slew/dwell/handoff on (required for those task types)." },
    "bearingDeg": { "type": "number", "minimum": 0, "maximum": 360, "description": "Bearing for SLEW/SEARCH when no track is referenced." },
    "searchVolume": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "centerBearingDeg": { "type": "number", "minimum": 0, "maximum": 360 },
        "widthDeg": { "type": "number", "minimum": 0, "maximum": 360 },
        "minAltMeters": { "type": "number" },
        "maxAltMeters": { "type": "number" }
      }
    },
    "handoffToSensorId": { "type": "string", "description": "Destination sensor for HANDOFF." },
    "priority": { "type": "integer", "minimum": 0, "maximum": 9, "description": "Higher wins arbitration when sensors contend." },
    "requestedBy": { "type": "string", "description": "Requesting principal (for authority check + audit)." },
    "expiresAt": { "type": "string", "format": "date-time", "description": "Task auto-expires; prevents stale tasking holding a sensor." }
  },
  "allOf": [
    {
      "if": { "properties": { "taskType": { "enum": ["CUE", "SLEW", "DWELL"] } } },
      "then": { "required": ["trackId"] }
    },
    {
      "if": { "properties": { "taskType": { "const": "HANDOFF" } } },
      "then": { "required": ["trackId", "handoffToSensorId"] }
    }
  ]
}

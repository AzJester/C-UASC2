{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuas.mil/schemas/detection.schema.json",
  "title": "Detection",
  "description": "A single sensor's raw observation prior to fusion. Fusion correlates detections from multiple sensors into one Track.",
  "type": "object",
  "required": ["detectionId", "sensorId", "position", "timeObserved"],
  "additionalProperties": false,
  "properties": {
    "detectionId": { "type": "string" },
    "sensorId": { "type": "string", "description": "Producing sensor identity." },
    "position": {
      "type": "object",
      "required": ["lat", "lon", "altMeters"],
      "additionalProperties": false,
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
        "altMeters": { "type": "number" },
        "frame": { "type": "string", "enum": ["WGS84"], "default": "WGS84" },
        "altitudeReference": { "type": "string", "enum": ["WGS84_ELLIPSOID", "MSL", "AGL", "UNKNOWN"], "default": "UNKNOWN" }
      }
    },
    "measuredVelocity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speedMps": { "type": "number", "minimum": 0 },
        "courseDeg": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "verticalRateMps": { "type": "number" }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Sensor-reported detection confidence." },
    "snrDb": { "type": "number", "description": "Signal-to-noise where applicable." },
    "rfSignature": { "type": "string", "description": "RF/protocol signature where applicable (informs CID)." },
    "modality": { "type": "string", "enum": ["RADAR", "RF", "EO", "IR", "ACOUSTIC", "OTHER"] },
    "measurementUncertainty": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "referenceFrame": { "type": "string", "enum": ["LOCAL_ENU"] },
        "confidenceLevel": { "type": "string", "enum": ["ONE_SIGMA", "NINETY_FIVE_PERCENT"] },
        "eastVarianceM2": { "type": "number", "minimum": 0 },
        "northVarianceM2": { "type": "number", "minimum": 0 },
        "upVarianceM2": { "type": "number", "minimum": 0 },
        "eastNorthCovarianceM2": { "type": "number" }
      }
    },
    "observationSequence": { "type": "integer", "minimum": 0 },
    "measurementLatencyMilliseconds": { "type": "integer", "minimum": 0 },
    "timeObserved": { "type": "string", "format": "date-time" },
    "timePublished": { "type": "string", "format": "date-time" },
    "modelProvenance": { "type": "string", "maxLength": 256 }
  }
}

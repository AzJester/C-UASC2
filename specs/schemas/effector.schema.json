{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuas.mil/schemas/effector.schema.json",
  "title": "EffectorStatus",
  "description": "Effector registration/health/readiness. Published to cuas.effector.status.{effectorId}. No pairing to any sensor is recorded; pairing is computed at decision time (Imperative 5).",
  "type": "object",
  "required": ["effectorId", "effectorType", "readiness", "timeReported"],
  "additionalProperties": false,
  "properties": {
    "effectorId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9_:@/-]{0,127}$" },
    "effectorType": {
      "type": "string",
      "enum": ["EW_JAMMER", "RF_TAKEOVER", "KINETIC_GUN", "KINETIC_INTERCEPTOR", "DIRECTED_ENERGY", "NET_CAPTURE", "OTHER"],
      "description": "Effect class; informs weapon-target pairing and minimum-TQ policy."
    },
    "vendor": { "type": "string" },
    "readiness": { "type": "string", "enum": ["READY", "DEGRADED", "OFFLINE", "MAINTENANCE", "WEAPONS_HOLD"] },
    "magazine": {
      "type": "object",
      "description": "Remaining capacity (rounds, charge, etc.).",
      "additionalProperties": false,
      "required": ["remaining", "capacity", "unit"],
      "properties": {
        "remaining": { "type": "number", "minimum": 0 },
        "capacity": { "type": "number", "minimum": 0 },
        "unit": { "type": "string", "description": "rounds | shots | seconds | percent" }
      }
    },
    "engagementEnvelope": {
      "type": "object",
      "description": "Where this effector can engage; used by the feasibility gate.",
      "additionalProperties": false,
      "properties": {
        "location": {
          "type": "object",
          "required": ["lat", "lon", "altMeters"],
          "additionalProperties": false,
          "properties": {
            "lat": { "type": "number", "minimum": -90, "maximum": 90 },
            "lon": { "type": "number", "minimum": -180, "maximum": 180 },
            "altMeters": { "type": "number" },
            "frame": { "type": "string", "enum": ["WGS84"], "default": "WGS84" },
            "altitudeReference": { "type": "string", "enum": ["WGS84_ELLIPSOID", "MSL", "AGL", "UNKNOWN"], "default": "UNKNOWN" }
          }
        },
        "minRangeMeters": { "type": "number", "minimum": 0 },
        "maxRangeMeters": { "type": "number", "minimum": 0 },
        "minAltMeters": { "type": "number" },
        "maxAltMeters": { "type": "number" }
      }
    },
    "humanControl": {
      "type": "string",
      "enum": ["IN_THE_LOOP", "ON_THE_LOOP"],
      "description": "Supported human-control mode; bounded by ROE/weapons control status (see docs/05)."
    },
    "softwareVersion": { "type": "string" },
    "timeReported": { "type": "string", "format": "date-time" },
    "modelProvenance": {
      "type": "string",
      "maxLength": 256,
      "description": "Identifies notional/synthetic model provenance and must not be interpreted as field performance evidence."
    }
  }
}
